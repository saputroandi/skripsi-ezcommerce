{
  "name": "ezcommerce",
  "version": "1.0.0",
  "description": "Game top-up MVC application (SSR EJS + Express + PostgreSQL)",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "sequelize db:migrate",
    "seed": "sequelize db:seed:all",
    "swagger": "echo 'Swagger served at /api-docs'",

    "perf:smoke": "k6 run perf/k6/smoke.js",
    "perf:api": "k6 run perf/k6/api.js",
    "perf:order": "k6 run perf/k6/order-flow.js",
    "perf:rps": "k6 run perf/k6/rps.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.0.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "pg": "^8.11.5",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "sequelize-cli": "^6.6.2"
  },
  "engines": {
    "node": ">=18"
  }
}
