<section class="mb-6">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-extrabold tracking-tight text-gray-900">Keranjang</h1>
      <p class="text-sm text-gray-600">Cek ulang item sebelum checkout.</p>
    </div>
    <a href="/products" class="text-sm font-semibold text-rose-700 hover:underline">Tambah produk</a>
  </div>
</section>

<% const itemCount = items.length; %>
<section class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-6">
  <div class="space-y-4">
    <div class="rounded-2xl border border-rose-100 bg-white shadow-sm overflow-hidden">
      <div class="flex items-center justify-between px-5 py-4 border-b border-rose-100 bg-rose-50/60">
        <div>
          <h2 class="text-sm font-semibold text-gray-900">Daftar Produk</h2>
          <p class="text-xs text-gray-500">Total <span class="font-semibold text-gray-900" id="cartItemCount"><%= itemCount %></span> item.</p>
        </div>
      </div>
      <div class="p-5 space-y-3" id="cartList">
        <% if (!items.length) { %>
          <div class="rounded-xl border border-rose-100 bg-rose-50/40 p-4 text-sm text-gray-600">
            Keranjang masih kosong. Ayo pilih produk dulu.
          </div>
        <% } %>
        <% items.forEach(item => { %>
          <% const unitPrice = Number(item.VoucherPackage?.price) || 0; %>
          <div class="cartItem rounded-xl border border-rose-100 bg-white p-4" data-item-id="<%= item.id %>" data-unit-price="<%= unitPrice %>">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <div class="flex items-start gap-3">
                <label class="flex items-start gap-2 pt-1">
                  <input type="checkbox" class="itemCheck h-4 w-4 text-rose-600 focus:ring-rose-400" checked />
                  <span class="sr-only">Pilih produk</span>
                </label>
                <div>
                  <p class="font-semibold text-gray-900"><%= item.VoucherPackage?.Game?.name || '-' %></p>
                  <p class="text-xs text-gray-500"><%= item.VoucherPackage?.name || '-' %></p>
                </div>
              </div>
              <div class="flex flex-wrap items-center gap-3">
                <div class="flex items-center gap-2">
                  <button type="button" class="qtyMinus h-9 w-9 rounded-xl border border-rose-100 bg-white text-gray-700 hover:bg-rose-50" aria-label="Kurangi">-</button>
                  <input type="text" class="qtyInput w-14 text-center rounded-xl border border-rose-100 bg-white px-3 py-2 text-sm font-semibold text-gray-900" value="<%= item.quantity || 1 %>" readonly />
                  <button type="button" class="qtyPlus h-9 w-9 rounded-xl border border-rose-100 bg-white text-gray-700 hover:bg-rose-50" aria-label="Tambah">+</button>
                </div>
                <div class="text-right">
                  <p class="text-xs text-gray-500">Subtotal</p>
                  <p class="subtotal font-semibold text-gray-900">Rp <%= (unitPrice * (item.quantity || 1)).toLocaleString('id-ID') %></p>
                </div>
                <button type="button" class="removeItem text-xs font-semibold text-rose-700 hover:underline">Hapus</button>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <aside class="space-y-4">
    <div class="rounded-2xl border border-rose-100 bg-white p-5 shadow-sm">
      <p class="text-sm font-semibold text-gray-900">Ringkasan</p>
      <div class="mt-4 space-y-2 text-sm text-gray-700">
        <div class="flex items-center justify-between text-xs text-gray-500">
          <span>Dipilih</span>
          <span id="selectedCount"><%= itemCount %> item</span>
        </div>
        <div class="flex items-center justify-between border-t border-rose-100 pt-3">
          <span class="text-gray-600">Subtotal (dipilih)</span>
          <span class="text-lg font-semibold text-gray-900" id="cartTotal">Rp <%= totalPrice.toLocaleString('id-ID') %></span>
        </div>
      </div>
      <a id="checkoutBtn" href="/checkout" class="mt-5 w-full inline-flex items-center justify-center rounded-xl bg-rose-600 hover:bg-rose-700 text-white px-4 py-2.5 font-semibold <%= items.length ? '' : 'pointer-events-none opacity-50' %>">
        Checkout
      </a>
    </div>
  </aside>
</section>

<script>
  (function(){
    const list = document.getElementById('cartList');
    const totalEl = document.getElementById('cartTotal');
    const countEl = document.getElementById('cartItemCount');
    const selectedCountEl = document.getElementById('selectedCount');
    const checkoutBtn = document.getElementById('checkoutBtn');

    function formatRupiah(value){
      return 'Rp ' + Number(value || 0).toLocaleString('id-ID');
    }

    function updateSummary(){
      const rows = Array.from(document.querySelectorAll('.cartItem'));
      const selectedRows = rows.filter((row) => {
        const checkbox = row.querySelector('.itemCheck');
        return checkbox ? checkbox.checked : false;
      });
      let total = 0;
      selectedRows.forEach((row) => {
        const unit = Number(row.getAttribute('data-unit-price')) || 0;
        const qty = Number(row.querySelector('.qtyInput')?.value || 1);
        total += unit * qty;
      });
      if (totalEl) totalEl.textContent = formatRupiah(total);
      if (countEl) countEl.textContent = String(rows.length);
      if (selectedCountEl) selectedCountEl.textContent = `${selectedRows.length} item`;
      if (checkoutBtn) {
        if (selectedRows.length) {
          checkoutBtn.classList.remove('pointer-events-none', 'opacity-50');
          const ids = selectedRows.map((row) => row.getAttribute('data-item-id')).filter(Boolean);
          checkoutBtn.setAttribute('href', `/checkout?itemIds=${ids.join(',')}`);
        } else {
          checkoutBtn.classList.add('pointer-events-none', 'opacity-50');
          checkoutBtn.setAttribute('href', '/checkout');
        }
      }
      if (!rows.length && list) {
        list.innerHTML = '<div class="rounded-xl border border-rose-100 bg-rose-50/40 p-4 text-sm text-gray-600">Keranjang masih kosong. Ayo pilih produk dulu.</div>';
      }
    }

    async function updateItem(row, qty){
      const token = typeof getStoredToken === 'function' ? getStoredToken() : localStorage.getItem('token');
      if (!token) return;
      const id = row.getAttribute('data-item-id');
      const res = await fetch(`/api/cart/items/${id}`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + token
        },
        body: JSON.stringify({ quantity: qty })
      });
      if (!res.ok) {
        if (window.showToast) window.showToast('Gagal memperbarui jumlah.', 'error');
        return;
      }
      if (typeof window.refreshCartBadge === 'function') window.refreshCartBadge();
    }

    list?.addEventListener('change', (e)=>{
      const target = e.target;
      if (!(target instanceof HTMLElement)) return;
      if (target.classList.contains('itemCheck')) {
        updateSummary();
      }
    });

    list?.addEventListener('click', async (e)=>{
      const target = e.target;
      if (!(target instanceof HTMLElement)) return;
      const row = target.closest('.cartItem');
      if (!row) return;

      const qtyInput = row.querySelector('.qtyInput');
      const unit = Number(row.getAttribute('data-unit-price')) || 0;
      let qty = Number(qtyInput?.value || 1);

      if (target.classList.contains('qtyMinus')) {
        qty = Math.max(1, qty - 1);
      }
      if (target.classList.contains('qtyPlus')) {
        qty = Math.min(999, qty + 1);
      }
      if (target.classList.contains('qtyMinus') || target.classList.contains('qtyPlus')) {
        if (qtyInput) qtyInput.value = String(qty);
        const subtotal = row.querySelector('.subtotal');
        if (subtotal) subtotal.textContent = formatRupiah(unit * qty);
        updateSummary();
        await updateItem(row, qty);
        return;
      }

      if (target.classList.contains('removeItem')) {
        const token = typeof getStoredToken === 'function' ? getStoredToken() : localStorage.getItem('token');
        if (!token) return;
        const id = row.getAttribute('data-item-id');
        const res = await fetch(`/api/cart/items/${id}`, {
          method: 'DELETE',
          headers: { 'Authorization': 'Bearer ' + token }
        });
        if (!res.ok) {
          if (window.showToast) window.showToast('Gagal menghapus item.', 'error');
          return;
        }
        row.remove();
        updateSummary();
        if (typeof window.refreshCartBadge === 'function') window.refreshCartBadge();
      }
    });

    updateSummary();
  })();
</script>
