<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'EzBeauty' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --brand-rose: #f43f5e;
      --brand-rose-soft: #fff1f2;
    }
    body {
      font-family: 'Inter', system-ui, -apple-system, Segoe UI, sans-serif;
    }
    h1, h2, h3 {
      font-family: 'Playfair Display', 'Inter', serif;
      letter-spacing: -0.01em;
    }
  </style>
</head>
  <body class="min-h-screen flex flex-col bg-rose-50/60 text-gray-900">

  <!-- Toast container -->
  <div id="toastHost" class="fixed top-4 right-4 z-[9999] flex flex-col gap-2"></div>

  <nav class="sticky top-0 z-20 border-b border-gray-200 bg-white/85 backdrop-blur">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between gap-3">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/" class="font-extrabold tracking-tight text-lg shrink-0">
          <span class="text-gray-900">Ez</span><span class="text-rose-600">Beauty</span>
        </a>
        <span class="hidden sm:inline-flex text-xs px-2 py-1 rounded-full bg-rose-50 border border-rose-100 text-rose-700">Skincare & Beauty</span>
      </div>

      <!-- Desktop nav/actions -->
      <div class="hidden md:flex items-center gap-3" id="authBox">
        <a href="/products" class="text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-rose-50">Produk</a>
        <a href="/payment/bca" class="text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-rose-50">Panduan Pembayaran</a>
        <a href="/cart" id="cartLink" class="hidden relative text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-rose-50">
          Keranjang
          <span id="cartBadge" class="hidden absolute -top-1 -right-1 min-w-[18px] h-[18px] px-1 rounded-full bg-rose-600 text-white text-[10px] font-semibold flex items-center justify-center">0</span>
        </a>
        <a href="/admin/dashboard" id="adminLink" class="hidden text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-gray-50">Admin</a>
        <a href="/admin/products" id="adminGamesLink" class="hidden text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-rose-50">Kelola Produk</a>

        <a
          href="/login"
          id="loginPageBtn"
          class="hidden md:inline-flex items-center gap-2 rounded-xl border border-rose-200 bg-rose-50/60 hover:bg-rose-100/70 px-4 py-2 text-sm font-semibold text-rose-700 shadow-sm">
          Masuk
        </a>

        <div id="userMenuWrap" class="relative hidden">
          <button type="button" id="userMenuBtn" class="flex items-center gap-2 rounded-xl border border-rose-100 bg-white px-3 py-2 text-sm font-semibold text-gray-800 hover:bg-rose-50" aria-haspopup="true" aria-expanded="false">
            <span id="userEmail" class="max-w-[180px] truncate">-</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="text-gray-500">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div id="userMenu" class="absolute right-0 mt-2 w-52 rounded-xl border border-rose-100 bg-white shadow-lg hidden">
            <a href="/profile" id="profileLink" class="block px-4 py-2 text-sm text-gray-700 hover:bg-rose-50">Alamat</a>
            <a href="/orders" id="ordersLink" class="block px-4 py-2 text-sm text-gray-700 hover:bg-rose-50">Transaksi</a>
            <div class="border-t border-rose-100 my-1"></div>
            <button type="button" id="logoutBtn" class="w-full text-left px-4 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-50">Logout</button>
          </div>
        </div>
      </div>

      <!-- Mobile actions (no overflow) -->
      <div class="md:hidden flex items-center gap-2">
        <a href="/login" id="mobileLoginBtn" class="bg-rose-600 hover:bg-rose-700 text-white px-3 py-2 rounded-lg text-sm font-semibold">
          Login
        </a>
        <button type="button" id="mobileMenuBtn" class="inline-flex items-center justify-center h-10 w-10 rounded-xl border border-rose-100 bg-white hover:bg-rose-50 text-gray-700" aria-label="Open menu" aria-expanded="false">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu panel -->
    <div id="mobileMenu" class="md:hidden hidden border-t border-gray-200 bg-white">
      <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-2">
        <a href="/products" class="text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-rose-50">Produk</a>
        <a href="/payment/bca" class="text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-rose-50">Panduan Pembayaran</a>
        <a href="/cart" id="cartLinkMobile" class="hidden relative text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-rose-50">
          Keranjang
          <span id="cartBadgeMobile" class="hidden absolute top-1/2 -translate-y-1/2 right-3 min-w-[18px] h-[18px] px-1 rounded-full bg-rose-600 text-white text-[10px] font-semibold flex items-center justify-center">0</span>
        </a>
        <a href="/profile" id="profileLinkMobile" class="hidden text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-rose-50">Alamat</a>
        <a href="/orders" id="ordersLinkMobile" class="hidden text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-gray-50">Transaksi</a>
        <a href="/admin/dashboard" id="adminLinkMobile" class="hidden text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-gray-50">Admin</a>
        <a href="/admin/products" id="adminGamesLinkMobile" class="hidden text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-rose-50">Kelola Produk</a>

        <div id="mobileUserRow" class="hidden items-center justify-between gap-3 px-3 py-2 rounded-lg bg-gray-50 border border-gray-200">
          <span id="userEmailMobile" class="text-sm font-semibold text-gray-800 truncate">-</span>
          <button type="button" id="logoutBtnMobile" class="hidden bg-white hover:bg-gray-50 border border-gray-200 text-gray-800 px-3 py-2 rounded-lg text-sm">Logout</button>
        </div>
      </div>
    </div>
  </nav>

  <main class="relative max-w-6xl mx-auto px-4 flex-1 w-full py-8">
    <%- body %>
  </main>

  <footer class="relative border-t border-rose-100 py-8 text-center text-sm text-gray-500 bg-white">
    &copy; <%= new Date().getFullYear() %> EzBeauty
  </footer>

  <div class="fixed bottom-5 right-5 z-[9999]">
    <a
      href="https://wa.me/6281574832133?text=Hai%20kak%20mau%20tanya%20produk%20EzBeauty"
      target="_blank"
      rel="noopener"
      class="h-14 w-14 rounded-2xl bg-emerald-500 hover:bg-emerald-600 text-white shadow-xl flex items-center justify-center"
      aria-label="Hubungi via WhatsApp"
      title="Hubungi via WhatsApp">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12.04 2C6.55 2 2.08 6.47 2.08 11.96c0 1.93.54 3.81 1.57 5.45L2 22l4.71-1.62a9.9 9.9 0 0 0 5.33 1.55h.01c5.49 0 9.96-4.47 9.96-9.96a9.9 9.9 0 0 0-2.92-7.06A9.9 9.9 0 0 0 12.04 2zm5.73 14.15c-.24.68-1.4 1.29-1.93 1.36-.5.07-1.13.1-1.82-.12-.42-.13-.96-.31-1.66-.62-2.92-1.27-4.83-4.37-4.98-4.58-.15-.2-1.2-1.6-1.2-3.05 0-1.45.76-2.17 1.03-2.46.27-.29.59-.37.79-.37.2 0 .4 0 .58.01.18.01.43-.07.67.51.24.59.81 2.02.88 2.17.07.15.12.33.03.53-.09.2-.14.33-.29.5-.15.17-.31.38-.44.51-.15.15-.31.31-.13.62.18.31.82 1.36 1.76 2.2 1.21 1.07 2.23 1.4 2.54 1.56.31.16.49.13.67-.08.18-.21.77-.9.97-1.21.2-.31.41-.26.69-.16.28.1 1.78.84 2.09.99.31.15.52.23.6.36.08.13.08.74-.16 1.42z"/>
      </svg>
    </a>
  </div>

  <script>
    // Global toast helper
    (function(){
      const host = document.getElementById('toastHost');
      window.showToast = function(message, type = 'error', ttl = 3200){
        if (!host) return;
        const el = document.createElement('div');
        const style = type === 'success'
          ? 'border-emerald-200 bg-emerald-50 text-emerald-800'
          : (type === 'info'
            ? 'border-indigo-200 bg-indigo-50 text-indigo-800'
            : 'border-rose-200 bg-rose-50 text-rose-800');

        el.className = `min-w-[260px] max-w-sm rounded-xl border px-4 py-3 shadow-sm ${style}`;
        el.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="mt-0.5 h-2.5 w-2.5 rounded-full ${type === 'success' ? 'bg-emerald-500' : (type === 'info' ? 'bg-indigo-500' : 'bg-rose-500')}"></div>
            <div class="text-sm leading-snug">${String(message || '').replace(/</g,'&lt;')}</div>
          </div>
        `;

        host.appendChild(el);
        requestAnimationFrame(() => el.classList.add('opacity-100'));

        setTimeout(() => {
          el.classList.add('opacity-0');
          el.addEventListener('transitionend', () => el.remove(), { once: true });
          // fallback
          setTimeout(() => el.remove(), 500);
        }, ttl);
      };
    })();

    const mobileLoginBtn = document.getElementById('mobileLoginBtn');
    const loginPageBtn = document.getElementById('loginPageBtn');

    const userMenuWrap = document.getElementById('userMenuWrap');
    const userMenuBtn = document.getElementById('userMenuBtn');
    const userMenu = document.getElementById('userMenu');
    const userEmailEl = document.getElementById('userEmail');
    const logoutBtn = document.getElementById('logoutBtn');
    const cartLink = document.getElementById('cartLink');
    const cartBadge = document.getElementById('cartBadge');
    const adminLink = document.getElementById('adminLink');
    const ordersLink = document.getElementById('ordersLink');
    const adminGamesLink = document.getElementById('adminGamesLink');
    const profileLink = document.getElementById('profileLink');

    // Mobile menu elements
    const mobileMenuBtn = document.getElementById('mobileMenuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    const adminLinkMobile = document.getElementById('adminLinkMobile');
    const ordersLinkMobile = document.getElementById('ordersLinkMobile');
    const adminGamesLinkMobile = document.getElementById('adminGamesLinkMobile');
    const profileLinkMobile = document.getElementById('profileLinkMobile');
    const cartLinkMobile = document.getElementById('cartLinkMobile');
    const cartBadgeMobile = document.getElementById('cartBadgeMobile');
    const mobileUserRow = document.getElementById('mobileUserRow');
    const userEmailMobile = document.getElementById('userEmailMobile');
    const logoutBtnMobile = document.getElementById('logoutBtnMobile');

    function openLoginModal(){
      const redirect = encodeURIComponent(location.pathname + location.search);
      location.href = `/login?redirect=${redirect}`;
    }

    function closeMobileMenu(){
      if (!mobileMenu || !mobileMenuBtn) return;
      mobileMenu.classList.add('hidden');
      mobileMenuBtn.setAttribute('aria-expanded', 'false');
    }

    function closeUserMenu(){
      if (!userMenu || !userMenuBtn) return;
      userMenu.classList.add('hidden');
      userMenuBtn.setAttribute('aria-expanded', 'false');
    }

    window.addEventListener('keydown', (e)=>{
      if (e.key === 'Escape') closeMobileMenu();
      if (e.key === 'Escape') closeUserMenu();
    });

    mobileMenuBtn?.addEventListener('click', ()=>{
      if (!mobileMenu || !mobileMenuBtn) return;
      const isHidden = mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      mobileMenuBtn.setAttribute('aria-expanded', String(isHidden));
    });

    userMenuBtn?.addEventListener('click', (e)=>{
      e.stopPropagation();
      if (!userMenu || !userMenuBtn) return;
      const isHidden = userMenu.classList.contains('hidden');
      userMenu.classList.toggle('hidden');
      userMenuBtn.setAttribute('aria-expanded', String(isHidden));
    });

    document.addEventListener('click', (e)=>{
      if (!userMenu || !userMenuBtn) return;
      if (userMenu.classList.contains('hidden')) return;
      if (userMenu.contains(e.target) || userMenuBtn.contains(e.target)) return;
      closeUserMenu();
    });

    userMenu?.addEventListener('click', ()=>{
      closeUserMenu();
    });

    function setTokenCookie(token){
      // 1 day; allow SSR pages to read via cookie header
      document.cookie = `token=${encodeURIComponent(token)}; Path=/; Max-Age=${60*60*24}`;
    }

    function clearTokenCookie(){
      document.cookie = 'token=; Path=/; Max-Age=0';
    }

    function getCookieToken(){
      const match = document.cookie.match(/(?:^|;\s*)token=([^;]+)/);
      return match ? decodeURIComponent(match[1]) : '';
    }

    function getStoredToken(){
      const token = localStorage.getItem('token');
      if (token) return token;
      const cookieToken = getCookieToken();
      if (cookieToken) {
        localStorage.setItem('token', cookieToken);
        return cookieToken;
      }
      return '';
    }

    async function refreshCartBadge(){
      const token = getStoredToken();
      if (!token) {
        cartBadge?.classList.add('hidden');
        cartBadgeMobile?.classList.add('hidden');
        return;
      }
      try {
        const res = await fetch('/api/cart', { headers: { 'Authorization': 'Bearer ' + token } });
        if (!res.ok) throw new Error('cart');
        const data = await res.json().catch(()=>({}));
        const items = Array.isArray(data?.items) ? data.items : [];
        const count = items.reduce((sum, item) => sum + (Number(item.quantity) || 0), 0);
        if (count > 0) {
          if (cartBadge) {
            cartBadge.textContent = String(count);
            cartBadge.classList.remove('hidden');
          }
          if (cartBadgeMobile) {
            cartBadgeMobile.textContent = String(count);
            cartBadgeMobile.classList.remove('hidden');
          }
        } else {
          cartBadge?.classList.add('hidden');
          cartBadgeMobile?.classList.add('hidden');
        }
      } catch {
        cartBadge?.classList.add('hidden');
        cartBadgeMobile?.classList.add('hidden');
      }
    }

    window.refreshCartBadge = refreshCartBadge;

    function showLoginUI(){
      loginPageBtn?.classList.remove('hidden', 'md:hidden');
      // mobile button visible on <md only
      mobileLoginBtn?.classList.remove('hidden');
      userMenuWrap?.classList.add('hidden');
      closeUserMenu();
      // mobile menu auth
      mobileUserRow?.classList.add('hidden');
      userEmailMobile && (userEmailMobile.textContent = '-');
      logoutBtnMobile?.classList.add('hidden');
      profileLink?.classList.add('hidden');
      profileLinkMobile?.classList.add('hidden');
      cartLink?.classList.add('hidden');
      cartLinkMobile?.classList.add('hidden');
      cartBadge?.classList.add('hidden');
      cartBadgeMobile?.classList.add('hidden');
    }

    function hideLoginUI(){
      loginPageBtn?.classList.add('hidden', 'md:hidden');
      // hide mobile login button
      mobileLoginBtn?.classList.add('hidden');
      userMenuWrap?.classList.remove('hidden');
    }

    async function refreshAuthUI(){
      const token = getStoredToken();
      if(!token){
        showLoginUI();
        logoutBtn?.classList.add('hidden');
        adminLink?.classList.add('hidden');
        adminGamesLink?.classList.add('hidden');
        ordersLink?.classList.add('hidden');
        profileLink?.classList.add('hidden');
        cartLink?.classList.add('hidden');

        // mobile menu links
        adminLinkMobile?.classList.add('hidden');
        adminGamesLinkMobile?.classList.add('hidden');
        ordersLinkMobile?.classList.add('hidden');
        profileLinkMobile?.classList.add('hidden');
        cartLinkMobile?.classList.add('hidden');
        mobileUserRow?.classList.add('hidden');
        logoutBtnMobile?.classList.add('hidden');
        userEmailMobile && (userEmailMobile.textContent = '-');

        clearTokenCookie();
        return;
      }
      // hide login CTAs immediately to avoid flicker while verifying
      hideLoginUI();
      userEmailEl && (userEmailEl.textContent = '...');
      try {
        const meRes = await fetch('/api/auth/me', { headers: { 'Authorization': 'Bearer '+token } });
        if(meRes.ok){
          const me = await meRes.json();
          if (userEmailEl) userEmailEl.textContent = me.email;
          if (userEmailMobile) userEmailMobile.textContent = me.email;
          hideLoginUI();
          logoutBtn?.classList.remove('hidden');
          profileLink?.classList.remove('hidden');
          profileLink?.classList.remove('hidden');
          cartLink?.classList.remove('hidden');

          // default: hide transaksi, will be enabled for non-admin
          ordersLink?.classList.add('hidden');
          ordersLinkMobile?.classList.add('hidden');
          profileLinkMobile?.classList.remove('hidden');
          cartLinkMobile?.classList.remove('hidden');
          refreshCartBadge();

          // mobile menu links
          mobileUserRow?.classList.remove('hidden');
          logoutBtnMobile?.classList.remove('hidden');
          profileLinkMobile?.classList.remove('hidden');

          if (me.role === 'admin') {
            // admin links on
            adminLink?.classList.remove('hidden');
            adminGamesLink?.classList.remove('hidden');
            adminLinkMobile?.classList.remove('hidden');
            adminGamesLinkMobile?.classList.remove('hidden');

            // IMPORTANT: do NOT force redirect admin away from public pages
            // (admin may want to inspect what users see)
          } else {
            adminLink?.classList.add('hidden');
            adminGamesLink?.classList.add('hidden');
            adminLinkMobile?.classList.add('hidden');
            adminGamesLinkMobile?.classList.add('hidden');

            // user can access transaksi
          ordersLink?.classList.remove('hidden');
          ordersLinkMobile?.classList.remove('hidden');
          }
          setTokenCookie(token);
        } else {
          localStorage.removeItem('token');
          showLoginUI();
          logoutBtn?.classList.add('hidden');
          adminLink?.classList.add('hidden');
          adminGamesLink?.classList.add('hidden');
          ordersLink?.classList.add('hidden');
          profileLink?.classList.add('hidden');
          cartLink?.classList.add('hidden');
          cartBadge?.classList.add('hidden');

          adminLinkMobile?.classList.add('hidden');
          adminGamesLinkMobile?.classList.add('hidden');
          ordersLinkMobile?.classList.add('hidden');
          profileLinkMobile?.classList.add('hidden');
          cartLinkMobile?.classList.add('hidden');
          cartBadgeMobile?.classList.add('hidden');
          mobileUserRow?.classList.add('hidden');
          logoutBtnMobile?.classList.add('hidden');
          userEmailMobile && (userEmailMobile.textContent = '-');

          clearTokenCookie();
        }
      } catch(err){
        localStorage.removeItem('token');
        showLoginUI();
        logoutBtn?.classList.add('hidden');
        adminLink?.classList.add('hidden');
        adminGamesLink?.classList.add('hidden');
        ordersLink?.classList.add('hidden');
        profileLink?.classList.add('hidden');
        cartLink?.classList.add('hidden');

        adminLinkMobile?.classList.add('hidden');
        adminGamesLinkMobile?.classList.add('hidden');
        ordersLinkMobile?.classList.add('hidden');
        profileLinkMobile?.classList.add('hidden');
        cartLinkMobile?.classList.add('hidden');
        mobileUserRow?.classList.add('hidden');
        logoutBtnMobile?.classList.add('hidden');
        userEmailMobile && (userEmailMobile.textContent = '-');

        clearTokenCookie();
      }
    }

    mobileLoginBtn?.addEventListener('click', openLoginModal);

    logoutBtn?.addEventListener('click', ()=>{
      localStorage.removeItem('token');
      clearTokenCookie();
      showLoginUI();
      logoutBtn?.classList.add('hidden');
      adminLink?.classList.add('hidden');
      adminGamesLink?.classList.add('hidden');
      ordersLink?.classList.add('hidden');
      profileLink?.classList.add('hidden');
      cartLink?.classList.add('hidden');

      // mobile
      adminLinkMobile?.classList.add('hidden');
      adminGamesLinkMobile?.classList.add('hidden');
      ordersLinkMobile?.classList.add('hidden');
      profileLinkMobile?.classList.add('hidden');
      cartLinkMobile?.classList.add('hidden');
      mobileUserRow?.classList.add('hidden');
      logoutBtnMobile?.classList.add('hidden');
      userEmailMobile && (userEmailMobile.textContent = '-');
      closeMobileMenu();

      if (location.pathname !== '/') location.href = '/';
      else refreshAuthUI();
    });

    logoutBtnMobile?.addEventListener('click', ()=>{
      // mirror desktop logout
      localStorage.removeItem('token');
      clearTokenCookie();
      showLoginUI();
      logoutBtn?.classList.add('hidden');
      adminLink?.classList.add('hidden');
      adminGamesLink?.classList.add('hidden');
      ordersLink?.classList.add('hidden');
      profileLink?.classList.add('hidden');
      cartLink?.classList.add('hidden');

      adminLinkMobile?.classList.add('hidden');
      adminGamesLinkMobile?.classList.add('hidden');
      ordersLinkMobile?.classList.add('hidden');
      mobileUserRow?.classList.add('hidden');
      logoutBtnMobile?.classList.add('hidden');
      userEmailMobile && (userEmailMobile.textContent = '-');
      closeMobileMenu();

      if (location.pathname !== '/') location.href = '/';
      else refreshAuthUI();
    });

    refreshAuthUI();
  </script>
</body>
</html>
