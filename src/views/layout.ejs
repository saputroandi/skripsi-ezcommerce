<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'EzCommerce' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen flex flex-col bg-gray-50 text-gray-900">

  <!-- Toast container -->
  <div id="toastHost" class="fixed top-4 right-4 z-[9999] flex flex-col gap-2"></div>

  <nav class="sticky top-0 z-20 border-b border-gray-200 bg-white/85 backdrop-blur">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between gap-3">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/" class="font-extrabold tracking-tight text-lg shrink-0">
          <span class="text-gray-900">Ez</span><span class="text-indigo-600">Commerce</span>
        </a>
        <span class="hidden sm:inline-flex text-xs px-2 py-1 rounded-full bg-indigo-50 border border-indigo-100 text-indigo-700">Top-up Game</span>
      </div>

      <!-- Desktop nav/actions -->
      <div class="hidden md:flex items-center gap-3" id="authBox">
        <a href="/games" class="text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-gray-50">Games</a>
        <a href="/payment/bca" class="text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-gray-50">Cara Bayar BCA</a>
        <a href="/orders" id="ordersLink" class="hidden text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-gray-50">Transaksi</a>
        <a href="/admin/dashboard" id="adminLink" class="hidden text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-gray-50">Admin</a>
        <a href="/admin/games" id="adminGamesLink" class="hidden text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-gray-50">Kelola Game</a>

        <!-- Desktop-only login form -->
        <form id="loginForm" class="hidden md:flex items-center gap-2 text-sm">
          <input name="email" placeholder="email" class="w-44 bg-white text-gray-900 placeholder:text-gray-400 border border-gray-200 px-3 py-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/40" />
          <input name="password" type="password" placeholder="password" class="w-36 bg-white text-gray-900 placeholder:text-gray-400 border border-gray-200 px-3 py-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/40" />
          <button class="bg-indigo-600 hover:bg-indigo-700 text-white px-3 py-2 rounded-lg">Login</button>
        </form>

        <span id="userEmail" class="text-sm font-semibold hidden px-3 py-2 rounded-lg bg-gray-50 border border-gray-200 text-gray-800"></span>
        <button type="button" id="logoutBtn" class="hidden bg-white hover:bg-gray-50 border border-gray-200 text-gray-800 px-3 py-2 rounded-lg">Logout</button>
      </div>

      <!-- Mobile actions (no overflow) -->
      <div class="md:hidden flex items-center gap-2">
        <button type="button" id="mobileLoginBtn" class="bg-indigo-600 hover:bg-indigo-700 text-white px-3 py-2 rounded-lg text-sm font-semibold">
          Login
        </button>
        <button type="button" id="mobileMenuBtn" class="inline-flex items-center justify-center h-10 w-10 rounded-xl border border-gray-200 bg-white hover:bg-gray-50 text-gray-700" aria-label="Open menu" aria-expanded="false">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu panel -->
    <div id="mobileMenu" class="md:hidden hidden border-t border-gray-200 bg-white">
      <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-2">
        <a href="/games" class="text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-gray-50">Games</a>
        <a href="/payment/bca" class="text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-gray-50">Cara Bayar BCA</a>
        <a href="/orders" id="ordersLinkMobile" class="hidden text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-gray-50">Transaksi</a>
        <a href="/admin/dashboard" id="adminLinkMobile" class="hidden text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-gray-50">Admin</a>
        <a href="/admin/games" id="adminGamesLinkMobile" class="hidden text-sm text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-gray-50">Kelola Game</a>

        <div class="flex items-center justify-between gap-3 px-3 py-2 rounded-lg bg-gray-50 border border-gray-200">
          <span id="userEmailMobile" class="text-sm font-semibold text-gray-800 truncate">-</span>
          <button type="button" id="logoutBtnMobile" class="hidden bg-white hover:bg-gray-50 border border-gray-200 text-gray-800 px-3 py-2 rounded-lg text-sm">Logout</button>
        </div>
      </div>
    </div>
  </nav>

  <!-- Mobile login modal -->
  <div id="loginModal" class="fixed inset-0 z-[9998] hidden">
    <div id="loginModalBackdrop" class="absolute inset-0 bg-black/30"></div>
    <div class="absolute inset-x-0 top-20 mx-auto w-[92%] max-w-md rounded-2xl border border-gray-200 bg-white shadow-xl overflow-hidden">
      <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200 bg-gray-50">
        <div>
          <p class="text-sm font-semibold text-gray-900">Login</p>
          <p class="text-xs text-gray-500">Masuk untuk melihat transaksi dan checkout.</p>
        </div>
        <button type="button" id="loginModalClose" class="h-9 w-9 rounded-xl border border-gray-200 bg-white hover:bg-gray-50 text-gray-700">✕</button>
      </div>

      <form id="mobileLoginForm" class="p-4 space-y-3">
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1">Email</label>
          <input name="email" placeholder="email" class="w-full bg-white text-gray-900 placeholder:text-gray-400 border border-gray-300 px-3 py-2 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/40" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1">Password</label>
          <input name="password" type="password" placeholder="password" class="w-full bg-white text-gray-900 placeholder:text-gray-400 border border-gray-300 px-3 py-2 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/40" />
        </div>
        <button class="w-full bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2.5 rounded-xl font-semibold">Login</button>
      </form>

      <div class="px-4 pb-4 text-xs text-gray-500">
        Akun test: <span class="font-mono">user1@example.com</span> / <span class="font-mono">User123!</span>
      </div>
    </div>
  </div>

  <main class="relative max-w-6xl mx-auto px-4 flex-1 w-full py-8">
    <%- body %>
  </main>

  <footer class="relative border-t border-gray-200 py-8 text-center text-sm text-gray-500 bg-white">
    &copy; <%= new Date().getFullYear() %> EzCommerce
  </footer>

  <!-- Chat widget -->
  <div id="chatWidget" class="fixed bottom-5 right-5 z-[9999] hidden">
    <!-- Popover -->
    <div id="chatPanel" class="hidden w-[340px] sm:w-[380px] max-h-[80vh] overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-xl flex flex-col">
      <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200 bg-gray-50">
        <div class="flex items-center gap-2">
          <div class="h-9 w-9 rounded-xl bg-indigo-600 flex items-center justify-center text-white font-bold">EZ</div>
          <div class="leading-tight">
            <p class="text-sm font-semibold text-gray-900">EzCommerce Assistant</p>
            <!-- <p class="text-xs text-gray-500">Demo</p> -->
          </div>
        </div>
        <button id="chatCloseBtn" type="button" class="h-9 w-9 rounded-xl border border-gray-200 bg-white hover:bg-gray-50 text-gray-700">✕</button>
      </div>

      <div id="chatMessages" class="flex-1 min-h-0 overflow-y-auto px-4 py-3 space-y-3 bg-white">
        <div class="flex items-start gap-2">
          <div class="h-8 w-8 rounded-xl bg-indigo-50 border border-indigo-100 flex items-center justify-center text-indigo-700 font-semibold">EZ</div>
          <div class="max-w-[260px] rounded-2xl rounded-tl-md border border-gray-200 bg-gray-50 px-3 py-2">
            <p class="text-sm text-gray-800">Halo! Aku bisa bantu cara top up, cara bayar, atau cek status (pakai nomor transaksi TRX).</p>
            <p class="mt-2 text-xs text-gray-500">Contoh: “cek trx TRX-20260114153045-1-3-9F2A”</p>
          </div>
        </div>
      </div>

      <div class="px-4 pb-3 bg-white">
        <div class="flex flex-wrap gap-2">
          <button type="button" class="chatQuick text-xs px-3 py-1.5 rounded-full border border-gray-200 bg-white hover:bg-gray-50 text-gray-700" data-q="Cara bayar?">Cara bayar?</button>
          <button type="button" class="chatQuick text-xs px-3 py-1.5 rounded-full border border-gray-200 bg-white hover:bg-gray-50 text-gray-700" data-q="Cara top up?">Cara top up?</button>
          <button type="button" class="chatQuick text-xs px-3 py-1.5 rounded-full border border-gray-200 bg-white hover:bg-gray-50 text-gray-700" data-q="Cek status transaksi saya">Cek status</button>
        </div>
      </div>

      <form id="chatForm" class="flex items-center gap-2 px-4 py-3 border-t border-gray-200 bg-white">
        <input id="chatInput" name="message" autocomplete="off" placeholder="Tulis pesan..."
          class="flex-1 bg-white text-gray-900 placeholder:text-gray-400 border border-gray-300 px-3 py-2 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400" />
        <button class="px-4 py-2 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white font-semibold">Kirim</button>
      </form>
    </div>

    <!-- Floating button -->
    <button id="chatFab" type="button" class="h-14 w-14 rounded-2xl bg-indigo-600 hover:bg-indigo-700 text-white shadow-xl flex items-center justify-center" aria-label="Open chat" title="Chat">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 5.5C4 4.119 5.119 3 6.5 3h11C18.881 3 20 4.119 20 5.5v7c0 1.381-1.119 2.5-2.5 2.5H10l-4.2 3.15c-.66.495-1.8.024-1.8-.8V15C4.895 15 4 14.105 4 13V5.5Z" stroke="white" stroke-width="1.8" stroke-linejoin="round"/>
        <path d="M7 7.8h10M7 11h7" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <script>
    // Global toast helper
    (function(){
      const host = document.getElementById('toastHost');
      window.showToast = function(message, type = 'error', ttl = 3200){
        if (!host) return;
        const el = document.createElement('div');
        const style = type === 'success'
          ? 'border-emerald-200 bg-emerald-50 text-emerald-800'
          : (type === 'info'
            ? 'border-indigo-200 bg-indigo-50 text-indigo-800'
            : 'border-rose-200 bg-rose-50 text-rose-800');

        el.className = `min-w-[260px] max-w-sm rounded-xl border px-4 py-3 shadow-sm ${style}`;
        el.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="mt-0.5 h-2.5 w-2.5 rounded-full ${type === 'success' ? 'bg-emerald-500' : (type === 'info' ? 'bg-indigo-500' : 'bg-rose-500')}"></div>
            <div class="text-sm leading-snug">${String(message || '').replace(/</g,'&lt;')}</div>
          </div>
        `;

        host.appendChild(el);
        requestAnimationFrame(() => el.classList.add('opacity-100'));

        setTimeout(() => {
          el.classList.add('opacity-0');
          el.addEventListener('transitionend', () => el.remove(), { once: true });
          // fallback
          setTimeout(() => el.remove(), 500);
        }, ttl);
      };
    })();

    const lf = document.getElementById('loginForm');
    const mlf = document.getElementById('mobileLoginForm');
    const mobileLoginBtn = document.getElementById('mobileLoginBtn');
    const loginModal = document.getElementById('loginModal');
    const loginModalBackdrop = document.getElementById('loginModalBackdrop');
    const loginModalClose = document.getElementById('loginModalClose');

    const userEmailEl = document.getElementById('userEmail');
    const logoutBtn = document.getElementById('logoutBtn');
    const adminLink = document.getElementById('adminLink');
    const ordersLink = document.getElementById('ordersLink');
    const adminGamesLink = document.getElementById('adminGamesLink');

    // Mobile menu elements
    const mobileMenuBtn = document.getElementById('mobileMenuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    const adminLinkMobile = document.getElementById('adminLinkMobile');
    const ordersLinkMobile = document.getElementById('ordersLinkMobile');
    const adminGamesLinkMobile = document.getElementById('adminGamesLinkMobile');
    const userEmailMobile = document.getElementById('userEmailMobile');
    const logoutBtnMobile = document.getElementById('logoutBtnMobile');

    function openLoginModal(){
      if (!loginModal) return;
      loginModal.classList.remove('hidden');
      const emailInput = loginModal.querySelector('input[name="email"]');
      setTimeout(() => emailInput?.focus(), 50);
    }

    function closeLoginModal(){
      loginModal?.classList.add('hidden');
    }

    function closeMobileMenu(){
      if (!mobileMenu || !mobileMenuBtn) return;
      mobileMenu.classList.add('hidden');
      mobileMenuBtn.setAttribute('aria-expanded', 'false');
    }

    mobileLoginBtn?.addEventListener('click', openLoginModal);
    loginModalBackdrop?.addEventListener('click', closeLoginModal);
    loginModalClose?.addEventListener('click', closeLoginModal);
    window.addEventListener('keydown', (e)=>{
      if (e.key === 'Escape' && loginModal && !loginModal.classList.contains('hidden')) closeLoginModal();
      if (e.key === 'Escape') closeMobileMenu();
    });

    mobileMenuBtn?.addEventListener('click', ()=>{
      if (!mobileMenu || !mobileMenuBtn) return;
      const isHidden = mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      mobileMenuBtn.setAttribute('aria-expanded', String(isHidden));
    });

    function setTokenCookie(token){
      // 1 day; allow SSR pages to read via cookie header
      document.cookie = `token=${encodeURIComponent(token)}; Path=/; Max-Age=${60*60*24}`;
    }

    function clearTokenCookie(){
      document.cookie = 'token=; Path=/; Max-Age=0';
    }

    function showLoginUI(){
      // desktop form visible on md+ only
      lf?.classList.add('hidden');
      lf?.classList.add('md:flex');
      // mobile button visible on <md only
      mobileLoginBtn?.classList.remove('hidden');
      // mobile menu auth
      userEmailMobile && (userEmailMobile.textContent = '-');
      logoutBtnMobile?.classList.add('hidden');
      closeLoginModal();
    }

    function hideLoginUI(){
      // hide desktop form
      lf?.classList.add('hidden');
      lf?.classList.remove('md:flex');
      // hide mobile login button
      mobileLoginBtn?.classList.add('hidden');
      closeLoginModal();
    }

    async function refreshAuthUI(){
      const token = localStorage.getItem('token');
      if(!token){
        showLoginUI();
        userEmailEl?.classList.add('hidden');
        logoutBtn?.classList.add('hidden');
        adminLink?.classList.add('hidden');
        adminGamesLink?.classList.add('hidden');
        ordersLink?.classList.add('hidden');

        // mobile menu links
        adminLinkMobile?.classList.add('hidden');
        adminGamesLinkMobile?.classList.add('hidden');
        ordersLinkMobile?.classList.add('hidden');
        logoutBtnMobile?.classList.add('hidden');
        userEmailMobile && (userEmailMobile.textContent = '-');

        clearTokenCookie();
        return;
      }
      try {
        const meRes = await fetch('/api/auth/me', { headers: { 'Authorization': 'Bearer '+token } });
        if(meRes.ok){
          const me = await meRes.json();
          if (userEmailEl) userEmailEl.textContent = me.email;
          if (userEmailMobile) userEmailMobile.textContent = me.email;
          hideLoginUI();
          userEmailEl?.classList.remove('hidden');
          logoutBtn?.classList.remove('hidden');

          // default: hide transaksi, will be enabled for non-admin
          ordersLink?.classList.add('hidden');
          ordersLinkMobile?.classList.add('hidden');

          // mobile menu links
          logoutBtnMobile?.classList.remove('hidden');

          if (me.role === 'admin') {
            // admin links on
            adminLink?.classList.remove('hidden');
            adminGamesLink?.classList.remove('hidden');
            adminLinkMobile?.classList.remove('hidden');
            adminGamesLinkMobile?.classList.remove('hidden');

            // IMPORTANT: do NOT force redirect admin away from public pages
            // (admin may want to inspect what users see)
          } else {
            adminLink?.classList.add('hidden');
            adminGamesLink?.classList.add('hidden');
            adminLinkMobile?.classList.add('hidden');
            adminGamesLinkMobile?.classList.add('hidden');

            // user can access transaksi
            ordersLink?.classList.remove('hidden');
            ordersLinkMobile?.classList.remove('hidden');
          }
          setTokenCookie(token);
        } else {
          localStorage.removeItem('token');
          showLoginUI();
          userEmailEl?.classList.add('hidden');
          logoutBtn?.classList.add('hidden');
          adminLink?.classList.add('hidden');
          adminGamesLink?.classList.add('hidden');
          ordersLink?.classList.add('hidden');

          adminLinkMobile?.classList.add('hidden');
          adminGamesLinkMobile?.classList.add('hidden');
          ordersLinkMobile?.classList.add('hidden');
          logoutBtnMobile?.classList.add('hidden');
          userEmailMobile && (userEmailMobile.textContent = '-');

          clearTokenCookie();
        }
      } catch(err){
        localStorage.removeItem('token');
        showLoginUI();
        userEmailEl?.classList.add('hidden');
        logoutBtn?.classList.add('hidden');
        adminLink?.classList.add('hidden');
        adminGamesLink?.classList.add('hidden');
        ordersLink?.classList.add('hidden');

        adminLinkMobile?.classList.add('hidden');
        adminGamesLinkMobile?.classList.add('hidden');
        ordersLinkMobile?.classList.add('hidden');
        logoutBtnMobile?.classList.add('hidden');
        userEmailMobile && (userEmailMobile.textContent = '-');

        clearTokenCookie();
      }
    }

    async function handleLoginSubmit(formEl){
      const fd = new FormData(formEl);
      const email = fd.get('email');
      const password = fd.get('password');

      const res = await fetch('/api/auth/login',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ email, password })
      });
      const data = await res.json();
      if(data.token){
        localStorage.setItem('token', data.token);
        setTokenCookie(data.token);
        await refreshAuthUI();
        closeLoginModal();

        // NOTE: tidak auto-redirect admin, supaya admin bisa tetap melihat halaman public (home/games)
      } else {
        if (window.showToast) window.showToast(data.message || 'Login gagal', 'error');
        else alert(data.message || 'Login gagal');
      }
    }

    lf?.addEventListener('submit', async (e)=>{
      e.preventDefault();
      await handleLoginSubmit(lf);
    });

    mlf?.addEventListener('submit', async (e)=>{
      e.preventDefault();
      await handleLoginSubmit(mlf);
    });

    logoutBtn?.addEventListener('click', ()=>{
      localStorage.removeItem('token');
      clearTokenCookie();
      showLoginUI();
      userEmailEl?.classList.add('hidden');
      logoutBtn?.classList.add('hidden');
      adminLink?.classList.add('hidden');
      adminGamesLink?.classList.add('hidden');
      ordersLink?.classList.add('hidden');

      // mobile
      adminLinkMobile?.classList.add('hidden');
      adminGamesLinkMobile?.classList.add('hidden');
      ordersLinkMobile?.classList.add('hidden');
      logoutBtnMobile?.classList.add('hidden');
      userEmailMobile && (userEmailMobile.textContent = '-');
      closeMobileMenu();

      if (location.pathname !== '/') location.href = '/';
      else refreshAuthUI();
    });

    logoutBtnMobile?.addEventListener('click', ()=>{
      // mirror desktop logout
      localStorage.removeItem('token');
      clearTokenCookie();
      showLoginUI();
      userEmailEl?.classList.add('hidden');
      logoutBtn?.classList.add('hidden');
      adminLink?.classList.add('hidden');
      adminGamesLink?.classList.add('hidden');
      ordersLink?.classList.add('hidden');

      adminLinkMobile?.classList.add('hidden');
      adminGamesLinkMobile?.classList.add('hidden');
      ordersLinkMobile?.classList.add('hidden');
      logoutBtnMobile?.classList.add('hidden');
      userEmailMobile && (userEmailMobile.textContent = '-');
      closeMobileMenu();

      if (location.pathname !== '/') location.href = '/';
      else refreshAuthUI();
    });

    refreshAuthUI();

    // Chat widget (all pages, user-only; admin pages hidden)
    (function(){
      const widget = document.getElementById('chatWidget');
      const fab = document.getElementById('chatFab');
      const panel = document.getElementById('chatPanel');
      const closeBtn = document.getElementById('chatCloseBtn');
      const form = document.getElementById('chatForm');
      const input = document.getElementById('chatInput');
      const messages = document.getElementById('chatMessages');

      if (!widget || !fab || !panel || !form || !input || !messages || !closeBtn) return;

      // Hide on admin pages
      if (location.pathname.startsWith('/admin')) return;

      widget.classList.remove('hidden');

      function openChat(){
        panel.classList.remove('hidden');
        fab.classList.add('hidden');
        setTimeout(() => input.focus(), 50);
        messages.scrollTo({ top: messages.scrollHeight, behavior: 'smooth' });
      }
      function closeChat(){
        panel.classList.add('hidden');
        fab.classList.remove('hidden');
      }

      function esc(s){
        return String(s).replace(/[&<>"']/g, (c)=>({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c]));
      }

      function addUserBubble(text){
        const wrap = document.createElement('div');
        wrap.className = 'flex justify-end';
        wrap.innerHTML = `
          <div class="max-w-[280px] rounded-2xl rounded-tr-md bg-indigo-600 text-white px-3 py-2">
            <p class="text-sm">${esc(text)}</p>
          </div>
        `;
        messages.appendChild(wrap);
      }

      function addBotBubble(text){
        const wrap = document.createElement('div');
        wrap.className = 'flex items-start gap-2';
        wrap.innerHTML = `
          <div class="h-8 w-8 rounded-xl bg-indigo-50 border border-indigo-100 flex items-center justify-center text-indigo-700 font-semibold">EZ</div>
          <div class="max-w-[260px] rounded-2xl rounded-tl-md border border-gray-200 bg-gray-50 px-3 py-2">
            <p class="text-sm text-gray-800">${esc(text)}</p>
          </div>
        `;
        messages.appendChild(wrap);
      }

      function botTyping(){
        const typing = document.createElement('div');
        typing.className = 'flex items-start gap-2';
        typing.innerHTML = `
          <div class="h-8 w-8 rounded-xl bg-indigo-50 border border-indigo-100 flex items-center justify-center text-indigo-700 font-semibold">EZ</div>
          <div class="max-w-[260px] rounded-2xl rounded-tl-md border border-gray-200 bg-gray-50 px-3 py-2">
            <p class="text-sm text-gray-500">Mengetik...</p>
          </div>
        `;
        messages.appendChild(typing);
        messages.scrollTo({ top: messages.scrollHeight, behavior: 'smooth' });
        return typing;
      }

      function isLoggedIn(){
        return Boolean(localStorage.getItem('token'));
      }

      async function sendToAI(message){
        if (!isLoggedIn()) {
          return 'Untuk menggunakan fitur AI Chat, kamu perlu login dulu. Silakan login, lalu coba lagi ya.';
        }

        const res = await fetch('/api/ai/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message })
        });

        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          return data?.message || 'Maaf, fitur chat belum bisa dipakai sekarang.';
        }
        return data?.reply || 'Maaf, aku belum punya jawaban untuk itu.';
      }

      fab.addEventListener('click', openChat);
      closeBtn.addEventListener('click', closeChat);

      document.querySelectorAll('.chatQuick').forEach(btn => {
        btn.addEventListener('click', async () => {
          const q = btn.getAttribute('data-q') || btn.textContent || '';
          if (!q) return;
          openChat();
          addUserBubble(q);
          const typing = botTyping();
          try {
            const reply = await sendToAI(q);
            typing.remove();
            addBotBubble(reply);
          } catch {
            typing.remove();
            addBotBubble('Maaf, terjadi kendala saat menghubungi server chat.');
          }
          messages.scrollTo({ top: messages.scrollHeight, behavior: 'smooth' });
        });
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const text = String(input.value || '').trim();
        if (!text) return;
        addUserBubble(text);
        input.value = '';
        const typing = botTyping();
        try {
          const reply = await sendToAI(text);
          typing.remove();
          addBotBubble(reply);
        } catch {
          typing.remove();
          addBotBubble('Maaf, terjadi kendala saat menghubungi server chat.');
        }
        messages.scrollTo({ top: messages.scrollHeight, behavior: 'smooth' });
      });

      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !panel.classList.contains('hidden')) closeChat();
      });
    })();
  </script>
</body>
</html>
