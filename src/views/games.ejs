<h1 class="text-3xl font-extrabold tracking-tight text-white mb-2">Semua Game</h1>
<p class="text-sm text-gray-400 mb-6">Pilih game, lanjut top-up.</p>

<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
  <% games.forEach(g => { %>
    <a href="/games/<%= g.id %>/buy" class="group rounded-2xl overflow-hidden border border-white/10 bg-white/5 hover:bg-white/10 transition">
      <div class="relative">
        <% if (g.thumbnailUrl) { %>
          <img src="<%= g.thumbnailUrl %>" alt="<%= g.name %>" class="w-full h-28 md:h-32 object-cover" />
        <% } else { %>
          <div class="w-full h-28 md:h-32 bg-white/5"></div>
        <% } %>
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition"></div>
      </div>
      <div class="p-3">
        <p class="font-semibold text-white leading-snug"><%= g.name %></p>
        <div class="mt-1 flex items-center justify-between">
          <p class="text-xs text-gray-400">
            <%
              const genreText = (g.Genres && g.Genres.length)
                ? g.Genres.map(x => x.name).join(', ')
                : '';
            %>
            <%= genreText %>
          </p>
          <span class="text-xs text-indigo-200 opacity-0 group-hover:opacity-100 transition">Top-up →</span>
        </div>
      </div>
    </a>
  <% }) %>
</div>
