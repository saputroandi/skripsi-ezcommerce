<section class="max-w-3xl">
    <div class="rounded-2xl border border-rose-100 bg-white shadow-sm p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-extrabold tracking-tight text-gray-900">Instruksi Pembayaran</h1>
        <p class="mt-2 text-sm text-gray-600">Silakan transfer ke rekening berikut, lalu unggah bukti pembayaran di halaman transaksi.</p>
      </div>
      <span class="inline-flex items-center rounded-full border border-rose-200 bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-700">Transfer Bank</span>
    </div>

    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-rose-100 bg-rose-50/60 p-4">
        <p class="text-xs font-semibold text-gray-500">Bank</p>
        <p class="mt-1 text-base font-semibold text-gray-900">BCA</p>
      </div>
      <div class="rounded-xl border border-rose-100 bg-rose-50/60 p-4">
        <p class="text-xs font-semibold text-gray-500">Nama Rekening</p>
        <p class="mt-1 text-base font-semibold text-gray-900">Andi Saputro</p>
      </div>
      <div class="rounded-xl border border-rose-100 bg-rose-50/60 p-4 sm:col-span-2">
        <p class="text-xs font-semibold text-gray-500">Nomor Rekening</p>
        <p class="mt-1 text-xl font-semibold tracking-widest text-gray-900">6281040003</p>
      </div>
    </div>

    <div id="orderSummary" class="mt-6 hidden rounded-xl border border-rose-100 bg-white p-4">
      <p class="text-sm font-semibold text-gray-900">Total Pembayaran</p>
      <div class="mt-2 flex items-center justify-between">
        <div>
          <p id="orderTrx" class="text-xs text-gray-500">-</p>
          <p id="orderItem" class="text-sm text-gray-700">-</p>
        </div>
        <div class="text-lg font-bold text-gray-900">
          Rp <span id="orderTotal">-</span>
        </div>
      </div>
    </div>

    <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
      <p class="font-semibold">Catatan penting</p>
      <ul class="mt-2 list-disc pl-5 space-y-1">
        <li>Pastikan nominal transfer sesuai total pesanan.</li>
        <li>Simpan bukti transfer untuk diunggah.</li>
        <li>Verifikasi dilakukan setelah bukti pembayaran diunggah.</li>
      </ul>
    </div>

    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <a href="/orders" class="inline-flex items-center justify-center rounded-xl bg-rose-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-rose-700">Upload Bukti Pembayaran</a>
      <a href="/products" class="inline-flex items-center justify-center rounded-xl border border-rose-100 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:bg-rose-50">Kembali Belanja</a>
    </div>
  </div>
</section>

<script>
  (function(){
    const orderId = '<%= orderId || "" %>';
    if (!orderId) return;

    function getToken(){
      const token = localStorage.getItem('token');
      if (token) return token;
      const match = document.cookie.match(/(?:^|;\s*)token=([^;]+)/);
      return match ? decodeURIComponent(match[1]) : '';
    }

    async function loadOrder(){
      const token = getToken();
      if (!token) return;
      const res = await fetch(`/api/orders/${encodeURIComponent(orderId)}`, {
        headers: { Authorization: 'Bearer ' + token }
      });
      if (!res.ok) return;
      const data = await res.json();
      const summary = document.getElementById('orderSummary');
      const trx = document.getElementById('orderTrx');
      const item = document.getElementById('orderItem');
      const total = document.getElementById('orderTotal');
      if (!summary || !trx || !item || !total) return;

      const game = data?.VoucherPackage?.Game?.name || '';
      const variant = data?.VoucherPackage?.name || '';
      const qty = data?.quantity || 1;
      const label = [game, variant].filter(Boolean).join(' • ');

      trx.textContent = data?.transactionCode ? `Kode: ${data.transactionCode}` : `Order #${data?.id || ''}`;
      item.textContent = label ? `${label} (x${qty})` : `Jumlah: ${qty}`;
      total.textContent = Number(data?.finalPrice || 0).toLocaleString('id-ID');
      summary.classList.remove('hidden');
    }

    loadOrder();
  })();
</script>
