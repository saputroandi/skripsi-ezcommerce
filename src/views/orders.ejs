<section class="mb-6">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-extrabold tracking-tight text-gray-900">Transaksi Saya</h1>
      <p class="text-sm text-gray-600">Daftar transaksi yang pernah kamu buat.</p>
    </div>

    <div class="flex flex-col sm:flex-row sm:items-center gap-3 min-w-0">
      <form method="GET" action="/orders" class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2 w-full sm:w-auto">
        <input
          type="text"
          name="q"
          value="<%= typeof q !== 'undefined' ? q : '' %>"
          placeholder="Cari nomor transaksi..."
          class="w-full sm:w-80 md:w-96 rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500"
        />
        <div class="flex items-center gap-2">
          <button class="w-full sm:w-auto rounded-xl border border-gray-200 bg-white hover:bg-gray-50 px-3 py-2 text-sm font-semibold text-gray-800">Search</button>
          <% if (typeof q !== 'undefined' && q) { %>
            <a href="/orders" class="text-sm text-indigo-700 hover:underline">Reset</a>
          <% } %>
        </div>
      </form>

      <div class="flex flex-col items-start sm:items-end gap-2">
        <div class="text-xs text-gray-500">Total: <span class="font-semibold text-gray-900"><%= orders.length %></span> order</div>
        <a href="/payment/bca" class="text-xs font-semibold text-indigo-700 hover:underline">Instruksi pembayaran BCA</a>
      </div>
    </div>
  </div>
</section>

<section>
  <% const needsProof = orders.some(o => (o.status || 'pending') === 'pending' && !o.paymentProof); %>
  <div class="rounded-2xl border border-gray-200 bg-white shadow-sm overflow-hidden">
  <% if (needsProof) { %>
    <div class="px-4 py-3 border-b border-gray-200 bg-gray-50">
      <p class="text-sm text-gray-700">Sudah transfer? Upload bukti pembayaran untuk mempercepat verifikasi admin.</p>
    </div>
  <% } %>
    <div class="overflow-x-auto">
      <table class="w-full min-w-[980px] text-sm">
        <thead class="bg-gray-50 border-b border-gray-200 text-gray-700">
          <tr>
            <th class="text-left px-4 py-3 font-semibold">No. Transaksi</th>
            <th class="text-left px-4 py-3 font-semibold">Tanggal</th>
            <th class="text-left px-4 py-3 font-semibold">Game</th>
            <th class="text-left px-4 py-3 font-semibold">Paket</th>
            <th class="text-left px-4 py-3 font-semibold">UID</th>
            <th class="text-left px-4 py-3 font-semibold">WhatsApp</th>
            <th class="text-left px-4 py-3 font-semibold">Total</th>
            <th class="text-left px-4 py-3 font-semibold">Status</th>
            <th class="text-left px-4 py-3 font-semibold">Bukti</th>
            <th class="text-left px-4 py-3 font-semibold">Aksi</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if (!orders.length) { %>
            <tr>
              <td colspan="10" class="px-4 py-10 text-center text-gray-500">Belum ada transaksi.</td>
            </tr>
          <% } %>

          <% orders.forEach(o => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-semibold text-gray-900">
                <%= o.transactionCode ? o.transactionCode : ('#' + o.id) %>
              </td>
              <td class="px-4 py-3 text-gray-700"><%= (o.createdAt ? new Date(o.createdAt).toLocaleString() : '-') %></td>
              <td class="px-4 py-3 text-gray-700"><%= o.VoucherPackage?.Game?.name || '-' %></td>
              <td class="px-4 py-3 text-gray-700"><%= o.VoucherPackage?.name || '-' %></td>
              <td class="px-4 py-3 text-gray-700"><%= o.uid %></td>
              <td class="px-4 py-3 text-gray-700"><%= o.whatsapp || '-' %></td>
              <td class="px-4 py-3 font-semibold text-gray-900">Rp <%= o.finalPrice %></td>
              <td class="px-4 py-3">
                <% const status = o.status || 'pending'; %>
                <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold border
                  <%= status === 'paid' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : (status === 'failed' ? 'bg-rose-50 text-rose-700 border-rose-200' : 'bg-amber-50 text-amber-700 border-amber-200') %>
                ">
                  <%= status %>
                </span>
              </td>
              <td class="px-4 py-3 text-gray-700">
                <% if (o.paymentProof) { %>
                  <button type="button" class="viewProofBtn text-indigo-700 hover:underline" data-url="<%= o.paymentProof %>">Lihat</button>
                <% } else { %>
                  <span class="text-gray-400">-</span>
                <% } %>
              </td>
              <td class="px-4 py-3">
                <% if ((o.status || 'pending') === 'pending') { %>
                  <button
                    type="button"
                    class="uploadProofBtn inline-flex items-center rounded-xl border border-gray-200 bg-white hover:bg-gray-50 px-3 py-2 text-xs font-semibold text-gray-800"
                    data-order-id="<%= o.id %>"
                    data-trx="<%= o.transactionCode || ('#' + o.id) %>">
                    Upload Bukti
                  </button>
                <% } else { %>
                  <span class="text-gray-400 text-xs">-</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- Proof preview modal -->
<div id="proofPreviewModal" class="fixed inset-0 z-[9998] hidden">
  <div id="proofPreviewBackdrop" class="absolute inset-0 bg-black/40"></div>
  <div class="absolute inset-x-0 top-10 sm:top-16 mx-auto w-[94%] max-w-3xl rounded-2xl border border-gray-200 bg-white shadow-xl overflow-hidden">
    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200 bg-gray-50">
      <div class="min-w-0">
        <p class="text-sm font-semibold text-gray-900">Bukti Pembayaran</p>
        <p class="text-xs text-gray-500 truncate">Preview file yang sudah diunggah.</p>
      </div>
      <button type="button" id="proofPreviewClose" class="h-9 w-9 rounded-xl border border-gray-200 bg-white hover:bg-gray-50 text-gray-700">✕</button>
    </div>
    <div class="p-4">
      <img id="proofPreviewImage" class="hidden w-full max-h-[70vh] object-contain rounded-xl border border-gray-200" alt="Bukti pembayaran" />
      <iframe id="proofPreviewFrame" class="hidden w-full h-[70vh] rounded-xl border border-gray-200" title="Bukti pembayaran"></iframe>
      <div class="mt-3 flex items-center justify-end">
        <a id="proofPreviewDownload" href="#" class="text-sm font-semibold text-indigo-700 hover:underline" target="_blank" rel="noreferrer">Download</a>
      </div>
    </div>
  </div>
</div>

<!-- Upload proof modal -->
<div id="proofModal" class="fixed inset-0 z-[9998] hidden">
  <div id="proofBackdrop" class="absolute inset-0 bg-black/30"></div>
  <div class="absolute inset-x-0 top-16 sm:top-20 mx-auto w-[94%] max-w-md rounded-2xl border border-gray-200 bg-white shadow-xl overflow-hidden">
    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200 bg-gray-50">
      <div class="min-w-0">
        <p class="text-sm font-semibold text-gray-900">Upload Bukti Pembayaran</p>
        <p id="proofTrx" class="text-xs text-gray-500 truncate">-</p>
      </div>
      <button type="button" id="proofClose" class="h-9 w-9 rounded-xl border border-gray-200 bg-white hover:bg-gray-50 text-gray-700">✕</button>
    </div>

    <form id="proofForm" class="p-4 space-y-3">
      <input type="hidden" name="orderId" id="proofOrderId" />
      <div>
        <label class="block text-xs font-semibold text-gray-700 mb-1">File bukti</label>
        <input id="proofFile" type="file" name="file" accept="image/*,.pdf" class="block w-full text-sm text-gray-700 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border file:border-gray-200 file:bg-white hover:file:bg-gray-50" />
        <p class="mt-1 text-xs text-gray-500">Maks 5MB. Format: JPG/PNG/WebP/PDF.</p>
      </div>
      <button id="proofSubmit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2.5 rounded-xl font-semibold">Upload</button>
    </form>
  </div>
</div>

<script>
(function(){
  const previewModal = document.getElementById('proofPreviewModal');
  const previewBackdrop = document.getElementById('proofPreviewBackdrop');
  const previewClose = document.getElementById('proofPreviewClose');
  const previewImg = document.getElementById('proofPreviewImage');
  const previewFrame = document.getElementById('proofPreviewFrame');
  const previewDownload = document.getElementById('proofPreviewDownload');

  function isPdfUrl(url){
    return /\.pdf($|[?#])/i.test(String(url || ''));
  }
  function isImageUrl(url){
    return /\.(png|jpe?g|webp|gif)($|[?#])/i.test(String(url || ''));
  }

  function openPreview(url){
    if (!previewModal || !previewImg || !previewFrame || !previewDownload) return;
    previewDownload.href = url || '#';
    previewImg.classList.add('hidden');
    previewFrame.classList.add('hidden');

    if (isImageUrl(url)) {
      previewImg.src = url;
      previewImg.classList.remove('hidden');
    } else {
      previewFrame.src = url;
      previewFrame.classList.remove('hidden');
    }

    previewModal.classList.remove('hidden');
  }

  function closePreview(){
    if (!previewModal || !previewImg || !previewFrame) return;
    previewModal.classList.add('hidden');
    previewImg.removeAttribute('src');
    previewFrame.removeAttribute('src');
  }

  document.querySelectorAll('.viewProofBtn').forEach((btn)=>{
    btn.addEventListener('click', ()=>{
      openPreview(btn.getAttribute('data-url'));
    });
  });

  previewBackdrop?.addEventListener('click', closePreview);
  previewClose?.addEventListener('click', closePreview);
  window.addEventListener('keydown', (e)=>{ if(e.key==='Escape' && previewModal && !previewModal.classList.contains('hidden')) closePreview(); });

  const modal = document.getElementById('proofModal');
  const backdrop = document.getElementById('proofBackdrop');
  const closeBtn = document.getElementById('proofClose');
  const form = document.getElementById('proofForm');
  const orderIdEl = document.getElementById('proofOrderId');
  const trxEl = document.getElementById('proofTrx');
  const submitBtn = document.getElementById('proofSubmit');

  if (!modal || !form) return;

  function openModal(orderId, trx){
    orderIdEl.value = orderId;
    trxEl.textContent = `No. Transaksi: ${trx}`;
    modal.classList.remove('hidden');
  }
  function closeModal(){
    modal.classList.add('hidden');
    form.reset();
  }

  document.querySelectorAll('.uploadProofBtn').forEach((btn)=>{
    btn.addEventListener('click', ()=>{
      openModal(btn.getAttribute('data-order-id'), btn.getAttribute('data-trx'));
    });
  });

  backdrop?.addEventListener('click', closeModal);
  closeBtn?.addEventListener('click', closeModal);
  window.addEventListener('keydown', (e)=>{ if(e.key==='Escape' && !modal.classList.contains('hidden')) closeModal(); });

  form.addEventListener('submit', async (e)=>{
    e.preventDefault();
    const token = localStorage.getItem('token');
    if (!token) {
      window.showToast?.('Silakan login dulu.', 'error');
      return;
    }

    const orderId = orderIdEl.value;
    const fd = new FormData(form);

    submitBtn.disabled = true;
    submitBtn.classList.add('opacity-60','cursor-not-allowed');

    try {
      const res = await fetch(`/api/orders/${orderId}/payment-proof`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` },
        body: fd
      });
      const data = await res.json();
      if (res.ok) {
        window.showToast?.('Bukti pembayaran berhasil diupload. Menunggu verifikasi admin.', 'success');
        closeModal();
        // refresh to show "Lihat" link
        setTimeout(()=>location.reload(), 600);
      } else {
        window.showToast?.(data.message || 'Upload gagal', 'error');
      }
    } catch (err) {
      window.showToast?.('Upload gagal', 'error');
    } finally {
      submitBtn.disabled = false;
      submitBtn.classList.remove('opacity-60','cursor-not-allowed');
    }
  });
})();
</script>
