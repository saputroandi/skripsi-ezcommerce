<% const hasDefault = addresses.some(a => a.isDefault); %>
<% const returnUrl = returnTo || '/checkout'; %>
<% const isDirect = typeof direct !== 'undefined' && direct; %>
<% const selectedIds = typeof selectedItemIds !== 'undefined' && Array.isArray(selectedItemIds) ? selectedItemIds : []; %>
<section class="mb-6">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-extrabold tracking-tight text-gray-900">Checkout</h1>
      <p class="text-sm text-gray-600">Pilih alamat pengiriman sebelum melanjutkan pembayaran.</p>
    </div>
    <a href="/profile" class="text-sm font-semibold text-rose-700 hover:underline">Kelola alamat</a>
  </div>
</section>

<section class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-6">
  <form id="checkoutForm" class="space-y-4">
    <div class="rounded-2xl border border-rose-100 bg-white shadow-sm overflow-hidden">
      <div class="flex items-center justify-between px-5 py-4 border-b border-rose-100 bg-rose-50/60">
        <div>
          <h2 class="text-sm font-semibold text-gray-900">Alamat Pengiriman</h2>
          <p class="text-xs text-gray-500">Pilih salah satu alamat yang tersimpan.</p>
        </div>
      </div>
      <div class="p-5 space-y-3">
        <% addresses.forEach((a, idx) => { %>
          <div class="rounded-xl border border-rose-100 bg-white hover:bg-rose-50/60">
            <label class="flex items-start gap-3 px-4 py-3 cursor-pointer">
              <input
                type="radio"
                name="addressId"
                value="<%= a.id %>"
                class="mt-1 h-4 w-4 text-rose-600 focus:ring-rose-400"
                <%= a.isDefault || (!hasDefault && idx === 0) ? 'checked' : '' %>
              />
              <span class="flex-1 text-sm text-gray-700">
                <span class="flex items-center gap-2">
                  <span class="font-semibold text-gray-900"><%= a.label || 'Alamat' %></span>
                  <% if (a.isDefault) { %>
                    <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-2 py-0.5 text-[10px] font-semibold text-emerald-700">Utama</span>
                  <% } %>
                </span>
                <span class="block text-xs text-gray-500">Penerima: <%= a.recipientName %></span>
                <% if (a.contactNumber) { %>
                  <span class="block text-xs text-gray-500">Kontak: <%= a.contactNumber %></span>
                <% } %>
                <span class="mt-1 block whitespace-pre-line text-gray-700"><%= a.address %></span>
                <span class="block text-xs text-gray-500"><%= [a.city, a.postalCode].filter(Boolean).join(' • ') %></span>
                <% if (a.notes) { %>
                  <span class="block text-xs text-gray-500">Catatan: <%= a.notes %></span>
                <% } %>
              </span>
            </label>
            <div class="flex items-center justify-between px-4 pb-3 text-xs text-gray-500">
              <span><%= a.isDefault ? 'Alamat utama checkout' : ' ' %></span>
              <% if (!a.isDefault) { %>
                <form method="POST" action="/profile/addresses/<%= a.id %>/default">
                  <input type="hidden" name="returnTo" value="<%= returnUrl %>" />
                  <button class="text-xs font-semibold text-rose-700 hover:underline">Jadikan alamat utama</button>
                </form>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

  </form>

  <aside class="space-y-4">
    <div class="rounded-2xl border border-rose-100 bg-white shadow-sm">
      <div class="px-5 py-4">
        <p class="text-sm text-gray-600">Pastikan alamat dan nomor kontak sudah benar sebelum melanjutkan.</p>
      </div>
    </div>

    <div class="rounded-2xl border border-rose-100 bg-white p-5 shadow-sm">
      <p class="text-sm font-semibold text-gray-900">Ringkasan Pesanan</p>
      <div class="mt-4 space-y-3 text-sm text-gray-700">
        <% items.forEach(item => { %>
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="font-semibold text-gray-900"><%= item.VoucherPackage?.Game?.name || '-' %></p>
              <p class="text-xs text-gray-500"><%= item.VoucherPackage?.name || '-' %></p>
            </div>
            <div class="text-right text-xs text-gray-500">
              x<%= item.quantity || 1 %>
              <div class="text-sm font-semibold text-gray-900">Rp <%= (Number(item.VoucherPackage?.price) * (item.quantity || 1)).toLocaleString('id-ID') %></div>
            </div>
          </div>
        <% }) %>
        <div class="flex items-center justify-between border-t border-rose-100 pt-3">
          <span class="text-gray-600">Total</span>
          <span class="text-lg font-semibold text-gray-900">Rp <%= totalPrice.toLocaleString('id-ID') %></span>
        </div>
      </div>

      <button id="submitCheckout" class="mt-5 w-full bg-rose-600 hover:bg-rose-700 text-white px-4 py-2.5 rounded-xl font-semibold">
        Lanjutkan Pembayaran
      </button>
    </div>

    <div class="rounded-2xl border border-rose-100 bg-white p-5 shadow-sm text-xs text-gray-500">
      Dengan checkout kamu setuju data alamat dipakai untuk pengiriman dan konfirmasi pesanan.
    </div>
  </aside>
</section>

<script>
  const checkoutForm = document.getElementById('checkoutForm');
  const submitBtn = document.getElementById('submitCheckout');
  const isDirect = <%= isDirect ? 'true' : 'false' %>;
  const directPayload = <%- JSON.stringify(directPayload || null) %>;
  const selectedItemIds = <%- JSON.stringify(selectedIds || []) %>;

  function getSelectedAddressId(){
    const checked = checkoutForm?.querySelector('input[name="addressId"]:checked');
    return checked ? Number(checked.value) : null;
  }

  submitBtn?.addEventListener('click', async (e)=>{
    e.preventDefault();
    const addressId = getSelectedAddressId();
    if (!addressId) {
      if (window.showToast) window.showToast('Pilih alamat terlebih dahulu.', 'info');
      return;
    }
    const token = typeof getStoredToken === 'function' ? getStoredToken() : localStorage.getItem('token');
    if (!token) {
      const redirect = encodeURIComponent(location.pathname + location.search);
      window.location.href = `/login?redirect=${redirect}`;
      return;
    }

    const payload = { addressId };
    const endpoint = isDirect ? '/api/orders' : '/api/cart/checkout';
    if (isDirect) {
      if (!directPayload?.voucherPackageId) {
        if (window.showToast) window.showToast('Item checkout tidak valid.', 'error');
        return;
      }
      payload.voucherPackageId = directPayload.voucherPackageId;
      payload.quantity = directPayload.quantity || 1;
      payload.uid = directPayload.uid || 'Checkout langsung';
    } else if (Array.isArray(selectedItemIds) && selectedItemIds.length) {
      payload.itemIds = selectedItemIds;
    }

    try {
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type':'application/json',
          'Authorization': 'Bearer ' + token
        },
        body: JSON.stringify(payload)
      });
      const data = await res.json().catch(()=>({}));
      if (!res.ok) {
        if (window.showToast) window.showToast(data?.message || 'Checkout gagal, coba lagi.', 'error');
        else alert(data?.message || 'Checkout gagal, coba lagi.');
        return;
      }
      if (window.showToast) window.showToast('Checkout berhasil. Lanjut ke halaman cara bayar.', 'success');
      const orderId = data?.id;
      const url = orderId ? `/payment/bca?orderId=${encodeURIComponent(orderId)}` : '/payment/bca';
      setTimeout(() => { window.location.href = url; }, 400);
    } catch {
      if (window.showToast) window.showToast('Checkout gagal, coba lagi.', 'error');
    }
  });
</script>
